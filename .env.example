# Karun Fruits — shared environment variables
#
# This single root .env is read by BOTH apps:
#   - frontend/ (Vite reads it via envDir, configured in frontend/vite.config.js)
#   - backend/  (Spring Boot reads it via spring.config.import in
#                backend/src/main/resources/application.yaml)
#
# Copy this file to ".env" in the repo root and fill in real values.
# The real .env is gitignored — never commit actual secrets.

# ============================================================
# FRONTEND (Vite) — frontend/
# Only variables prefixed with VITE_ are exposed to client code.
# ============================================================

VITE_API_URL=http://localhost:8080/api
VITE_RAZORPAY_KEY_ID=your_razorpay_key_id_here
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# ============================================================
# BACKEND (Spring Boot) — backend/
# All of these have safe defaults for local dev except where noted.
# ============================================================

# Database (defaults to postgres/password if unset)
DB_USERNAME=postgres
DB_PASSWORD=password

# JWT signing secret (has a default dev value; override in production)
JWT_SECRET=KarunFruitsSecretKeyForJWTTokenGenerationAndValidation2024VeryLongSecret

# Email (Gmail SMTP) — required for verification/reset emails
MAIL_USERNAME=
MAIL_PASSWORD=

# Razorpay payments — required for the payment flow
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Twilio SMS — required for SMS notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Shiprocket shipping integration
SHIPROCKET_EMAIL=
SHIPROCKET_PASSWORD=

# Google OAuth (shared with VITE_GOOGLE_CLIENT_ID above — same client ID)
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# CORS / email links — defaults to http://localhost:5173 if unset
FRONTEND_URL=http://localhost:5173
